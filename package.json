{
  "name": "online-exam-api",
  "version": "3.0.0",
  "description": "Modern, modular Node.js + Express REST API for an online exam platform.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "db:postgres": "psql \"$DATABASE_URL\" -f db/migrations/postgres.sql",
    "db:mssql": "sqlcmd -S \"$MSSQL_HOST\" -U \"$MSSQL_USER\" -P \"$MSSQL_PASSWORD\" -d \"$MSSQL_DATABASE\" -i db/migrations/mssql.sql"
  },
  "keywords": [
    "online-exam",
    "express",
    "node",
    "api",
    "jwt"
  ],
  "author": "Kashif Ahmad",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "uuid": "^9.0.1"
  },
  "optionalDependencies": {
    "mssql": "^11.0.1",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0"
  }
}
