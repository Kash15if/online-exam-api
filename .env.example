# Online Exam API – environment variables
NODE_ENV=development
PORT=8081
LOG_LEVEL=info

# Repository driver: memory | postgres | mssql
REPOSITORY_DRIVER=memory

# Postgres (used when REPOSITORY_DRIVER=postgres)
# Either set DATABASE_URL or the individual PG_* variables.
DATABASE_URL=
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
PG_DATABASE=online_exam
PG_SSL=false
PG_POOL_MAX=10

# MSSQL (used when REPOSITORY_DRIVER=mssql)
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASSWORD=
MSSQL_DATABASE=online_exam
MSSQL_ENCRYPT=false
MSSQL_TRUST_SERVER_CERTIFICATE=true
MSSQL_POOL_MAX=10

# JWT
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=24h

# Auth
BCRYPT_SALT_ROUNDS=10

# CORS (comma-separated list of allowed origins, * for any)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Rate limiting
RATE_LIMIT_MAX=100

# Body size
BODY_LIMIT=50kb

# Seeding (disable when running against a real production DB)
SEED_ON_BOOT=true
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin@12345
SEED_STUDENT_EMAIL=student@example.com
SEED_STUDENT_PASSWORD=Student@12345

# Auth bypass (development/demo only - blocked when NODE_ENV=production)
# When AUTH_BYPASS=true, every protected route is treated as authenticated as the
# AUTH_BYPASS_* user below. Useful for local UI work without logging in.
AUTH_BYPASS=false
AUTH_BYPASS_USER_ID=00000000-0000-0000-0000-0000000000aa
AUTH_BYPASS_EMAIL=bypass@example.com
AUTH_BYPASS_NAME=Bypass User
AUTH_BYPASS_ROLE=admin
